# =============================================================================
# Chartwise AI Backend - Environment Variables
# Copy this file to .env and fill in your actual values
# =============================================================================

# -----------------------------------------------------------------------------
# Database Configuration (REQUIRED)
# -----------------------------------------------------------------------------
# For local development with SQLite:
DATABASE_URL=sqlite:///./chartwise.db

# For production with PostgreSQL (Render.com automatically sets this):
# DATABASE_URL=postgresql://user:***@localhost:5432/chartwise

# -----------------------------------------------------------------------------
# Security Configuration (REQUIRED for production)
# -----------------------------------------------------------------------------
# Generate a strong secret key for JWT token signing
# You can generate one with: openssl rand -hex 32
SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# -----------------------------------------------------------------------------
# Frontend / CORS Configuration (REQUIRED for production)
# -----------------------------------------------------------------------------
# The URL of your frontend application (for CORS)
# Local development:
FRONTEND_URL=http://localhost:3000

# Production (Vercel):
# FRONTEND_URL=https://chartwise-ai.vercel.app

# -----------------------------------------------------------------------------
# API Configuration (Optional)
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# Set to False in production
DEBUG=True

# -----------------------------------------------------------------------------
# Scheduler Configuration (Optional)
# -----------------------------------------------------------------------------
# Enable automatic data updates
ENABLE_SCHEDULER=true

# How often to update data (in minutes)
UPDATE_INTERVAL_MINUTES=15

# -----------------------------------------------------------------------------
# Redis Configuration (Optional - for caching and Celery)
# -----------------------------------------------------------------------------
# Local development:
REDIS_URL=redis://localhost:6379/0

# Production (Render Redis):
# REDIS_URL=redis://red-xxxxxxxxxxxxxxxxxxxx:6379

# -----------------------------------------------------------------------------
# External API Keys (Required for data fetching)
# -----------------------------------------------------------------------------
# Alpha Vantage API (for stock data)
# Get your free API key at: https://www.alphavantage.co/support/#api-key
ALPHA_VANTAGE_API_KEY=your-alpha-vantage-api-key

# Binance API (for crypto data)
# Get your API keys at: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your-binance-api-key
BINANCE_SECRET_KEY=your-binance-secret-key

# -----------------------------------------------------------------------------
# Email Configuration (Optional - for notifications)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# -----------------------------------------------------------------------------
# Logging Configuration (Optional)
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FILE=server.log
